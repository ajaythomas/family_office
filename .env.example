# ── Local dev ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://family_office:family_office@localhost:5432/family_office
DATABASE_URL_TEST=postgresql://family_office:family_office@localhost:5432/family_office_test
GOOGLE_CLIENT_ID=<your-google-client-id>
JWT_SECRET=<run: python -c "import secrets; print(secrets.token_hex(32))">
# CORS_ORIGINS defaults to ["http://localhost:5173"] — no need to set in dev

# ── Production (Hetzner) — copy to .env on the server and fill in ────────────
# DATABASE_URL=postgresql://family_office:<password>@db:5432/family_office   ← hostname is "db" not localhost
# GOOGLE_CLIENT_ID=<same as dev>
# JWT_SECRET=<generate a fresh secret>
# CORS_ORIGINS=["https://your-domain.com"]
# APP_DOMAIN=your-domain.com
